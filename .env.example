# OSF Backend Environment Variables

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Port to run the server on (Render sets this dynamically, but locally use 5000)
PORT=5000

# Secret key for signing JWT tokens (use a random long string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# For CORS: Where requests are coming from
# In production, this MUST exactly match your Vercel Domain (no trailing slash)
# Example: https://my-frontend.vercel.app
CLIENT_URL=http://localhost:3000

# Environment Mode
NODE_ENV=development
